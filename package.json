{
  "name": "pi-depo",
  "version": "0.1.20",
  "description": "Declarative package manager for Pi Coding Agent - skills, extensions, hooks, MCP servers",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "package-manager"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "pd": "dist/cli.mjs"
  },
  "main": "./dist/cli.mjs",
  "scripts": {
    "build": "tsup",
    "dev": "bun run --watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.4",
    "@inquirer/core": "^11.1.9",
    "citty": "^0.2.2",
    "consigliere": "^2.0.0",
    "deepmerge": "^4.3.1",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fulgidus/pi-depo.git"
  },
  "author": "fulgidus"
}
